---
import type { Profile } from "@/data/schema";
import { safeImage } from "@/lib/content-utils";

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
---

<section id="hero-section" class="section-card" aria-labelledby="hero-title">
  <div style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;">
    <img
      id="hero-avatar"
      src={safeImage(profile.avatarUrl)}
      alt={`${profile.name} avatar`}
      width="96"
      height="96"
      style="border-radius:50%;border:2px solid rgba(148,163,184,.4);object-fit:cover;background:#0f172a;"
    />
    <div>
      <h1 id="hero-title" style="margin:.1rem 0 .2rem;letter-spacing:.3px;">{profile.name}</h1>
      <p id="hero-role" style="margin:0;color:var(--accent);font-weight:700;">{profile.role}</p>
      <p id="hero-experience" style="margin:.35rem 0 0;color:var(--muted);text-transform:capitalize;">
        Experience: {profile.experienceLevel}
      </p>
    </div>
  </div>
  {profile.headline && <p id="hero-headline" style="margin:1rem 0 0;">{profile.headline}</p>}
</section>
