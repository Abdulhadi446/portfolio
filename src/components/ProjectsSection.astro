---
import type { Project } from "@/data/schema";
import ProjectCard from "@/components/ProjectCard.astro";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
const highlightCount = projects.filter((item) => item.isAgenticAIHighlight).length;
---

<section class="section-card" aria-labelledby="projects-title">
  <div class="projects-header">
    <h2 id="projects-title" style="margin:0;">Projects</h2>
    <p id="projects-position" class="projects-position" aria-live="polite"></p>
  </div>
  {highlightCount < 1 || highlightCount > 2 ? (
    <p style="color:var(--danger);margin-top:0;">
      Data warning: projects should include 1 to 2 Agentic AI highlights.
    </p>
  ) : null}
  <div class="projects-rail" aria-label="Projects navigation controls">
    <button type="button" class="projects-nav-btn projects-nav-side" data-projects-nav="prev" aria-label="Show previous projects">
      ←
    </button>
    <div id="projects-list" class="projects-scroll" role="list" aria-label="Project cards">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <button type="button" class="projects-nav-btn projects-nav-side" data-projects-nav="next" aria-label="Show next projects">
      →
    </button>
  </div>
</section>

<script>
  const initProjectsPager = () => {
    const list = document.getElementById("projects-list");
    const position = document.getElementById("projects-position");
    const prevBtn = document.querySelector('[data-projects-nav="prev"]');
    const nextBtn = document.querySelector('[data-projects-nav="next"]');
    if (!list || !(prevBtn instanceof HTMLButtonElement) || !(nextBtn instanceof HTMLButtonElement)) return;

    const cards = Array.from(list.children);
    const getVisibleCount = () => (window.matchMedia("(max-width: 760px)").matches ? 1 : 2);
    let visibleCount = getVisibleCount();
    let start = 0;

    const maxStart = () => Math.max(0, cards.length - visibleCount);

    const render = () => {
      cards.forEach((card, index) => {
        const visible = index >= start && index < start + visibleCount;
        const wasHidden = card.hasAttribute("hidden");
        card.toggleAttribute("hidden", !visible);
        card.setAttribute("aria-hidden", String(!visible));
        if (visible && wasHidden) {
          card.classList.remove("project-card-enter");
          void card.offsetWidth;
          card.classList.add("project-card-enter");
        }
      });
      const disableNav = cards.length <= visibleCount;
      prevBtn.disabled = disableNav;
      nextBtn.disabled = disableNav;
      if (position) {
        const currentStart = cards.length === 0 ? 0 : start + 1;
        const currentEnd = cards.length === 0 ? 0 : Math.min(start + visibleCount, cards.length);
        position.textContent = `${currentStart}-${currentEnd} / ${cards.length}`;
      }
    };

    prevBtn.onclick = () => {
      if (cards.length <= visibleCount) return;
      start = start <= 0 ? maxStart() : start - 1;
      render();
    };

    nextBtn.onclick = () => {
      if (cards.length <= visibleCount) return;
      start = start >= maxStart() ? 0 : start + 1;
      render();
    };

    window.addEventListener(
      "resize",
      () => {
        const nextCount = getVisibleCount();
        if (nextCount === visibleCount) return;
        visibleCount = nextCount;
        start = Math.min(start, maxStart());
        render();
      },
      { passive: true }
    );

    render();
  };

  window.initializeProjectsPager = initProjectsPager;
  initProjectsPager();
</script>
